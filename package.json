{
  "name": "q-guard-server",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "Q-Guard",
  "type": "module",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "tsc  --noEmitOnError false",
    "dev": "nodemon src/index.ts",
    "start": "node --inspect dist/index.js",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs  migrate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs  push",
    "db:pull": "tsx node_modules/drizzle-kit/bin.cjs  pull",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "swagger": "tsx swagger.js",
    "swagger:watch": "nodemon --watch swagger-output.json --exec npm run swagger",
    "email:dev": "email dev --dir ./src/lib/email/templates --port 4401"
  },
  "imports": {
    "#app": "./dist/app.js",
    "#server": "./dist/index.js",
    "#config/*": "./dist/config/*",
    "#database/*": "./dist/database/*",
    "#errors/*": "./dist/errors/*",
    "#lib/*": "./dist/lib/*",
    "#middleware/*": "./dist/middleware/*",
    "#modules/*": "./dist/modules/*",
    "#router/*": "./dist/router/*",
    "#services/*": "./dist/services/*",
    "#types/*": "./dist/types/*",
    "#tasks/*": "./dist/tasks/*",
    "#utils/*": "./dist/utils/*"
  },
  "dependencies": {
    "@react-email/components": "1.0.7",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.67.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-xss-sanitizer": "^2.0.1",
    "file-type": "^21.3.0",
    "formidable": "^3.5.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "p-limit": "^7.3.0",
    "pg": "^8.18.0",
    "rate-limiter-flexible": "^9.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.10.0",
    "request-ip": "^3.3.0",
    "sirv": "^3.0.2",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "ulid": "^3.0.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.8",
    "@types/bcrypt": "^6.0.0",
    "@types/busboy": "^1.5.4",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-xss-sanitizer": "^2.0.0",
    "@types/formidable": "^3.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.13",
    "@types/request-ip": "^0.0.41",
    "@types/swagger-ui-express": "^4.1.8",
    "drizzle-kit": "^0.31.8",
    "nodemon": "^3.1.11",
    "oxlint": "^1.43.0",
    "prettier": "^3.8.1",
    "react-email": "5.2.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
